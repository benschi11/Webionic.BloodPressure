@page "/report"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Microsoft.EntityFrameworkCore
@using Webionic.BloodPressure.Data
@using Webionic.BloodPressure.Models
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Report – BlutdruckTracker</PageTitle>

<div class="container-fluid px-3">
    <h1 class="h4 mt-3 mb-3">📊 Report &amp; Graphen</h1>

    <div class="d-flex gap-2 mb-3 flex-wrap">
        <select class="form-select form-select-sm w-auto" @bind="filterDays" @bind:after="LoadData">
            <option value="7">Letzte 7 Tage</option>
            <option value="30">Letzte 30 Tage</option>
            <option value="90">Letzte 90 Tage</option>
            <option value="365">Letztes Jahr</option>
            <option value="0">Alle</option>
        </select>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-4">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (!entries.Any())
    {
        <div class="alert alert-info">Noch keine Messungen vorhanden. <a href="/">Jetzt messen!</a></div>
    }
    else
    {
        <!-- Statistics Cards -->
        <div class="row g-3 mb-4">
            <div class="col-6">
                <div class="card text-center shadow-sm border-primary">
                    <div class="card-body p-2">
                        <div class="text-muted small">Ø Systole</div>
                        <div class="fs-4 fw-bold text-primary">@avgSystole</div>
                        <div class="text-muted small">mmHg</div>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div class="card text-center shadow-sm border-info">
                    <div class="card-body p-2">
                        <div class="text-muted small">Ø Diastole</div>
                        <div class="fs-4 fw-bold text-info">@avgDiastole</div>
                        <div class="text-muted small">mmHg</div>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div class="card text-center shadow-sm border-success">
                    <div class="card-body p-2">
                        <div class="text-muted small">Ø Puls</div>
                        <div class="fs-4 fw-bold text-success">@avgPulse</div>
                        <div class="text-muted small">bpm</div>
                    </div>
                </div>
            </div>
            <div class="col-6">
                <div class="card text-center shadow-sm">
                    <div class="card-body p-2">
                        <div class="text-muted small">Messungen</div>
                        <div class="fs-4 fw-bold">@entries.Count</div>
                        <div class="text-muted small">gesamt</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Min/Max Table -->
        <div class="card shadow-sm mb-4">
            <div class="card-header">Min / Max Werte</div>
            <div class="card-body p-2">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr><th></th><th>Min</th><th>Max</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>Systole</td><td>@minSystole</td><td>@maxSystole</td></tr>
                        <tr><td>Diastole</td><td>@minDiastole</td><td>@maxDiastole</td></tr>
                        <tr><td>Puls</td><td>@minPulse</td><td>@maxPulse</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Blood Pressure Trend Chart -->
        <div class="card shadow-sm mb-4">
            <div class="card-header">Blutdruckverlauf</div>
            <div class="card-body">
                <div style="height: 250px; position: relative;">
                    <canvas id="bpChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Pulse Chart -->
        <div class="card shadow-sm mb-4">
            <div class="card-header">Pulsverlauf</div>
            <div class="card-body">
                <div style="height: 200px; position: relative;">
                    <canvas id="pulseChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Category Distribution -->
        <div class="card shadow-sm mb-4">
            <div class="card-header">Kategorie-Verteilung</div>
            <div class="card-body">
                <div style="height: 220px; position: relative;">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<BloodPressureEntry> entries = [];
    private bool isLoading = true;
    private int filterDays = 30;
    private bool chartsRendered = false;

    private int avgSystole, avgDiastole, avgPulse;
    private int minSystole, maxSystole, minDiastole, maxDiastole, minPulse, maxPulse;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!isLoading && entries.Any() && !chartsRendered)
        {
            chartsRendered = true;
            await RenderCharts();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        chartsRendered = false;
        await using var db = await DbFactory.CreateDbContextAsync();
        var query = db.BloodPressureEntries.AsQueryable();
        if (filterDays > 0)
            query = query.Where(e => e.MeasuredAt >= DateTime.Now.AddDays(-filterDays));
        entries = await query.OrderBy(e => e.MeasuredAt).ToListAsync();

        if (entries.Any())
        {
            avgSystole = (int)Math.Round(entries.Average(e => e.Systole));
            avgDiastole = (int)Math.Round(entries.Average(e => e.Diastole));
            avgPulse = (int)Math.Round(entries.Average(e => e.Pulse));
            minSystole = entries.Min(e => e.Systole);
            maxSystole = entries.Max(e => e.Systole);
            minDiastole = entries.Min(e => e.Diastole);
            maxDiastole = entries.Max(e => e.Diastole);
            minPulse = entries.Min(e => e.Pulse);
            maxPulse = entries.Max(e => e.Pulse);
        }

        isLoading = false;
    }

    private async Task RenderCharts()
    {
        var labels = entries.Select(e => e.MeasuredAt.ToString("dd.MM HH:mm")).ToArray();
        var systoleData = entries.Select(e => (object)e.Systole).ToArray();
        var diastoleData = entries.Select(e => (object)e.Diastole).ToArray();
        var pulseData = entries.Select(e => (object)e.Pulse).ToArray();

        // Blood pressure chart
        var bpDatasets = new[]
        {
            new { label = "Systole", data = systoleData, borderColor = "rgb(220, 53, 69)", backgroundColor = "rgba(220, 53, 69, 0.1)", tension = 0.3, fill = false },
            new { label = "Diastole", data = diastoleData, borderColor = "rgb(13, 110, 253)", backgroundColor = "rgba(13, 110, 253, 0.1)", tension = 0.3, fill = false }
        };

        await JS.InvokeVoidAsync("blazorInterop.renderChart", "bpChart", "line", labels, bpDatasets, null);

        // Pulse chart
        var pulseDatasets = new[]
        {
            new { label = "Puls", data = pulseData, borderColor = "rgb(25, 135, 84)", backgroundColor = "rgba(25, 135, 84, 0.1)", tension = 0.3, fill = true }
        };

        await JS.InvokeVoidAsync("blazorInterop.renderChart", "pulseChart", "line", labels, pulseDatasets, null);

        // Category distribution chart
        var categories = entries.GroupBy(e => e.BloodPressureCategory)
            .Select(g => new { Label = g.Key, Count = g.Count() })
            .ToList();

        var catLabels = categories.Select(c => c.Label).ToArray();
        var catData = categories.Select(c => (object)c.Count).ToArray();
        var catColors = categories.Select(c => entries.First(e => e.BloodPressureCategory == c.Label).CategoryCssClass switch
        {
            "success" => "rgba(25, 135, 84, 0.8)",
            "primary" => "rgba(13, 110, 253, 0.8)",
            "info" => "rgba(13, 202, 240, 0.8)",
            "warning" => "rgba(255, 193, 7, 0.8)",
            "danger" => "rgba(220, 53, 69, 0.8)",
            _ => "rgba(108, 117, 125, 0.8)"
        }).ToArray();

        var catDatasets = new[]
        {
            new { label = "Messungen", data = catData, backgroundColor = catColors }
        };

        var catOptions = new
        {
            responsive = true,
            maintainAspectRatio = false,
            plugins = new { legend = new { position = "right" } }
        };

        await JS.InvokeVoidAsync("blazorInterop.renderChart", "categoryChart", "doughnut", catLabels, catDatasets, catOptions);
    }

    public async ValueTask DisposeAsync()
    {
        await JS.InvokeVoidAsync("blazorInterop.destroyChart", "bpChart");
        await JS.InvokeVoidAsync("blazorInterop.destroyChart", "pulseChart");
        await JS.InvokeVoidAsync("blazorInterop.destroyChart", "categoryChart");
    }
}
