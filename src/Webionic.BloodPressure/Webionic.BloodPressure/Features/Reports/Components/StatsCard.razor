@using Webionic.BloodPressure.Features.Reports.Models

@if (Stats is not null && Stats.TotalReadings > 0)
{
    <div class="stat-grid">
        <div class="stat-card stat-systolic">
            <div class="stat-value">@Stats.AverageSystolic.ToString("F0")</div>
            <div class="stat-label">Ø Systole</div>
        </div>
        <div class="stat-card stat-diastolic">
            <div class="stat-value">@Stats.AverageDiastolic.ToString("F0")</div>
            <div class="stat-label">Ø Diastole</div>
        </div>
        <div class="stat-card stat-pulse">
            <div class="stat-value">@Stats.AveragePulse.ToString("F0")</div>
            <div class="stat-label">Ø Puls</div>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 8px;">
        <div style="background: #fce4e6; border-radius: 10px; padding: 10px 12px; text-align: center;">
            <div style="font-size: 0.7rem; color: #888; text-transform: uppercase;">Systole Min/Max</div>
            <div style="font-weight: 700; color: var(--bp-danger);">@Stats.MinSystolic / @Stats.MaxSystolic</div>
        </div>
        <div style="background: #dbeafe; border-radius: 10px; padding: 10px 12px; text-align: center;">
            <div style="font-size: 0.7rem; color: #888; text-transform: uppercase;">Diastole Min/Max</div>
            <div style="font-weight: 700; color: var(--bp-info);">@Stats.MinDiastolic / @Stats.MaxDiastolic</div>
        </div>
    </div>
}
else
{
    <div class="empty-state" style="padding: 24px;">
        <i class="bi bi-bar-chart d-block"></i>
        <p>Noch keine Statistiken verfügbar</p>
    </div>
}

@code {
    [Parameter] public BloodPressureStats? Stats { get; set; }
}
