@using Webionic.BloodPressure.Features.BloodPressure.Models

@if (Readings.Count == 0)
{
    <div class="empty-state">
        <i class="bi bi-journal-medical d-block"></i>
        <p>Noch keine Messungen vorhanden</p>
    </div>
}
else
{
    @foreach (var reading in Readings)
    {
        <div class="reading-item">
            <div class="reading-icon @GetClassification(reading.Systolic, reading.Diastolic)">
                <i class="bi bi-heart-pulse"></i>
            </div>
            <div class="reading-body">
                <div class="reading-values">
                    @reading.Systolic/@reading.Diastolic mmHg
                    <span style="color: var(--bp-success);">· @reading.Pulse bpm</span>
                </div>
                <div class="reading-meta">
                    @reading.Timestamp.AddMinutes(UtcOffsetMinutes).ToString("dd.MM.yyyy HH:mm")
                    @if (reading.ArmSide is not null)
                    {
                        <span> · @reading.ArmSide.ToDisplayText()</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(reading.Notes))
                    {
                        <span> · @reading.Notes</span>
                    }
                </div>
            </div>
            @if (OnEdit.HasDelegate)
            {
                <button class="reading-edit" @onclick="() => OnEdit.InvokeAsync(reading.Id)" title="Bearbeiten"
                        aria-label="Messung bearbeiten">
                    <i class="bi bi-pencil"></i>
                </button>
            }
            @if (OnDelete.HasDelegate)
            {
                <button class="reading-delete" @onclick="() => RequestDelete(reading.Id)" title="Löschen"
                        aria-label="Messung löschen">
                    <i class="bi bi-trash3"></i>
                </button>
            }
        </div>
        @if (_pendingDeleteId == reading.Id)
        {
            <div class="delete-confirm" role="alertdialog" aria-modal="true"
                 aria-labelledby="delete-confirm-title-@reading.Id">
                <span id="delete-confirm-title-@reading.Id">Messung wirklich löschen?</span>
                <div class="delete-confirm-actions">
                    <button class="btn btn-bp-danger-sm" @onclick="ConfirmDelete" aria-label="Löschen bestätigen">
                        Löschen
                    </button>
                    <button class="btn btn-bp-secondary-sm" @onclick="CancelDelete" aria-label="Abbrechen">
                        Abbrechen
                    </button>
                </div>
            </div>
        }
    }
}

@code {
    [Parameter] public List<BloodPressureReadingDto> Readings { get; set; } = [];
    [Parameter] public EventCallback<int> OnDelete { get; set; }
    [Parameter] public EventCallback<int> OnEdit { get; set; }
    [Parameter] public int UtcOffsetMinutes { get; set; }

    private int? _pendingDeleteId;

    private void RequestDelete(int id)
    {
        _pendingDeleteId = id;
    }

    private async Task ConfirmDelete()
    {
        if (_pendingDeleteId.HasValue)
        {
            var id = _pendingDeleteId.Value;
            _pendingDeleteId = null;
            await OnDelete.InvokeAsync(id);
        }
    }

    private void CancelDelete()
    {
        _pendingDeleteId = null;
    }

    private static string GetClassification(int systolic, int diastolic)
    {
        if (systolic < 120 && diastolic < 80) return "normal";
        if (systolic < 140 || diastolic < 90) return "elevated";
        return "high";
    }
}
