@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using Webionic.BloodPressure.Features.BloodPressure.Models
@inject IJSRuntime JS

<EditForm Model="Model" OnValidSubmit="HandleSubmit" FormName="@FormName" class="bp-form">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <label class="form-label">Systole (mmHg)</label>
        <div class="input-group">
            <InputNumber @bind-Value="Model.Systolic" class="form-control" placeholder="z.B. 120"
                         min="60" max="250" id="systolic-input" />
            <span class="input-group-text">mmHg</span>
        </div>
        <ValidationMessage For="@(() => Model.Systolic)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Diastole (mmHg)</label>
        <div class="input-group">
            <InputNumber @bind-Value="Model.Diastolic" class="form-control" placeholder="z.B. 80"
                         min="30" max="150" />
            <span class="input-group-text">mmHg</span>
        </div>
        <ValidationMessage For="@(() => Model.Diastolic)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Puls (bpm)</label>
        <div class="input-group">
            <InputNumber @bind-Value="Model.Pulse" class="form-control" placeholder="z.B. 72"
                         min="30" max="220" />
            <span class="input-group-text">bpm</span>
        </div>
        <ValidationMessage For="@(() => Model.Pulse)" />
    </div>

    <div class="mb-3">
        <label class="form-label">Datum & Uhrzeit</label>
        <div class="datetime-picker-group">
            <div class="datetime-picker-field">
                <i class="bi bi-calendar3"></i>
                <input type="date" class="form-control" value="@DateString" @onchange="OnDateChanged" />
            </div>
            <div class="datetime-picker-field">
                <i class="bi bi-clock"></i>
                <input type="time" class="form-control" value="@TimeString" @onchange="OnTimeChanged" />
            </div>
        </div>
        <ValidationMessage For="@(() => Model.Timestamp)" />
    </div>

    <div class="mb-4">
        <label class="form-label">Notizen (optional)</label>
        <InputTextArea @bind-Value="Model.Notes" class="form-control" placeholder="z.B. nach dem Sport, morgens..."
                       rows="2" style="resize: none;" />
    </div>

    <button type="submit" class="btn btn-bp-primary" disabled="@IsSubmitting">
        @if (IsSubmitting)
        {
            <span class="spinner-border spinner-border-sm me-2"></span>
        }
        <i class="bi bi-heart-pulse me-1"></i> Messung speichern
    </button>
</EditForm>

@code {
    [Parameter] public ReadingFormModel Model { get; set; } = new();
    [Parameter] public EventCallback<ReadingFormModel> OnSubmit { get; set; }
    [Parameter] public bool IsSubmitting { get; set; }
    [Parameter] public string FormName { get; set; } = "reading-form";

    private int _utcOffsetMinutes;

    private string DateString => Model.Timestamp.ToString("yyyy-MM-dd");
    private string TimeString => Model.Timestamp.ToString("HH:mm");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var localNow = await JS.InvokeAsync<string>("timezoneInterop.getBrowserLocalNow");
                if (DateTime.TryParseExact(localNow, "yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var localDateTime))
                {
                    Model.Timestamp = localDateTime;
                }
                _utcOffsetMinutes = await JS.InvokeAsync<int>("timezoneInterop.getBrowserUtcOffsetMinutes");
                StateHasChanged();
            }
            catch { /* JS not available */ }
        }
    }

    private void OnDateChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParseExact(e.Value?.ToString(), "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out var date))
        {
            var time = TimeOnly.FromTimeSpan(Model.Timestamp.TimeOfDay);
            Model.Timestamp = date.ToDateTime(time);
        }
    }

    private void OnTimeChanged(ChangeEventArgs e)
    {
        if (TimeOnly.TryParseExact(e.Value?.ToString(), "HH:mm", CultureInfo.InvariantCulture, DateTimeStyles.None, out var time))
        {
            var date = DateOnly.FromDateTime(Model.Timestamp);
            Model.Timestamp = date.ToDateTime(time);
        }
    }

    private async Task HandleSubmit()
    {
        var modelToSubmit = new ReadingFormModel
        {
            Systolic = Model.Systolic,
            Diastolic = Model.Diastolic,
            Pulse = Model.Pulse,
            Notes = Model.Notes,
            Timestamp = DateTime.SpecifyKind(Model.Timestamp.AddMinutes(-_utcOffsetMinutes), DateTimeKind.Utc)
        };
        await OnSubmit.InvokeAsync(modelToSubmit);
    }
}
