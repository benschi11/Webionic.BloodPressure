@page "/Account/ForgotPasswordConfirmation"

<PageTitle>Forgot password confirmation</PageTitle>

<div class="account-container">
    <div class="account-card">
        <div class="account-status-page">
            <i class="bi bi-envelope-fill" style="color: var(--bp-info);"></i>
            <h1>Forgot password confirmation</h1>
            <p role="alert">Please check your email to reset your password.</p>
        </div>
        <a href="Account/Login" class="btn btn-primary w-100">Back to login</a>
    </div>
</div>
