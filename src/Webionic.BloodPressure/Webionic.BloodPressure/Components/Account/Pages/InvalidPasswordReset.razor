@page "/Account/InvalidPasswordReset"

<PageTitle>Invalid password reset</PageTitle>

<div class="account-container">
    <div class="account-card">
        <div class="account-status-page">
            <i class="bi bi-exclamation-triangle-fill" style="color: var(--bp-warning);"></i>
            <h1>Invalid password reset</h1>
            <p role="alert">The password reset link is invalid.</p>
        </div>
        <a href="Account/ForgotPassword" class="btn btn-primary w-100">Request a new link</a>
    </div>
</div>
