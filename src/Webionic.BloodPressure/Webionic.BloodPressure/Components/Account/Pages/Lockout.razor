@page "/Account/Lockout"

<PageTitle>Locked out</PageTitle>

<div class="account-container">
    <div class="account-card">
        <div class="account-status-page">
            <i class="bi bi-lock-fill" style="color: var(--bp-danger);"></i>
            <h1 class="text-danger">Locked out</h1>
            <p role="alert">This account has been locked out, please try again later.</p>
        </div>
    </div>
</div>
