@page "/Account/ResetPasswordConfirmation"
<PageTitle>Reset password confirmation</PageTitle>

<div class="account-container">
    <div class="account-card">
        <div class="account-status-page">
            <i class="bi bi-check-circle-fill" style="color: var(--bp-success);"></i>
            <h1>Reset password confirmation</h1>
            <p role="alert">Your password has been reset.</p>
        </div>
        <a href="Account/Login" class="btn btn-primary w-100">Log in</a>
    </div>
</div>
